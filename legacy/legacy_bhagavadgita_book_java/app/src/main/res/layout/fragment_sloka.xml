<?xml version="1.0" encoding="utf-8"?>
<android.support.v4.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/white">

	<RelativeLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:descendantFocusability="beforeDescendants"
		android:focusableInTouchMode="true">

		<android.support.v7.widget.AppCompatImageView
			android:id="@+id/iv_prev"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_alignParentStart="true"
			android:layout_marginStart="6dp"
			android:clickable="true"
			android:focusable="true"
			android:padding="10dp"
			android:src="@drawable/ic_left" />

		<android.support.v7.widget.AppCompatImageView
			android:id="@+id/iv_next"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_alignParentEnd="true"
			android:layout_marginEnd="6dp"
			android:clickable="true"
			android:focusable="true"
			android:padding="10dp"
			android:src="@drawable/ic_right" />

		<com.ironwaterstudio.controls.TextViewEx
			android:id="@+id/tv_name"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_centerHorizontal="true"
			android:layout_marginLeft="40dp"
			android:layout_marginRight="40dp"
			android:layout_marginTop="10dp"
			android:gravity="center"
			android:textColor="@color/gray_1"
			android:textSize="24sp"
			app:fontEx="bold" />

		<com.ironwaterstudio.controls.TextViewEx
			android:id="@+id/tv_chapter"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_below="@id/tv_name"
			android:layout_centerHorizontal="true"
			android:layout_marginLeft="40dp"
			android:layout_marginRight="40dp"
			android:gravity="center"
			android:textColor="@color/gray_1"
			android:textSize="20sp"
			app:fontEx="bold" />

		<android.support.v7.widget.AppCompatImageView
			android:id="@+id/iv_sanskrit_divider"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_below="@id/tv_chapter"
			android:layout_centerHorizontal="true"
			android:layout_marginTop="21dp"
			android:src="@drawable/divider" />

		<com.ironwaterstudio.controls.TextViewEx
			android:id="@+id/tv_sanskrit"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_below="@id/iv_sanskrit_divider"
			android:layout_centerHorizontal="true"
			android:layout_marginLeft="16dp"
			android:layout_marginRight="16dp"
			android:layout_marginTop="22dp"
			android:gravity="center"
			android:textColor="@color/gray_1"
			android:textSize="18sp"
			app:fontEx="bold" />

		<com.ironwaterstudio.controls.TextViewEx
			android:id="@+id/tv_transcription"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_below="@id/tv_sanskrit"
			android:layout_centerHorizontal="true"
			android:layout_marginLeft="16dp"
			android:layout_marginRight="16dp"
			android:layout_marginTop="16dp"
			android:gravity="center"
			android:textColor="@color/gray_1"
			android:textSize="18sp"
			app:fontEx="italic" />

		<android.support.v7.widget.AppCompatImageView
			android:id="@+id/iv_translation_divider"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_below="@id/tv_transcription"
			android:layout_centerHorizontal="true"
			android:layout_marginTop="19dp"
			android:src="@drawable/divider" />

		<com.ironwaterstudio.controls.TextViewEx
			android:id="@+id/tv_translation"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_below="@id/iv_translation_divider"
			android:layout_centerHorizontal="true"
			android:layout_marginLeft="16dp"
			android:layout_marginRight="16dp"
			android:layout_marginTop="16dp"
			android:gravity="center"
			android:textColor="@color/gray_1"
			android:textSize="18sp" />

		<android.support.v7.widget.RecyclerView
			android:id="@+id/rv_translations"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_below="@id/tv_translation"
			android:layout_marginTop="24dp"
			android:background="@color/white"
			android:scrollbars="vertical"
			app:layoutManager="LinearLayoutManager" />

		<android.support.v7.widget.AppCompatImageView
			android:id="@+id/iv_commentary_divider"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_below="@id/rv_translations"
			android:layout_centerHorizontal="true"
			android:layout_marginTop="14dp"
			android:src="@drawable/divider" />

		<android.support.v7.widget.RecyclerView
			android:id="@+id/rv_commentary"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_below="@id/iv_commentary_divider"
			android:layout_marginTop="16dp"
			android:background="@color/white"
			android:scrollbars="vertical"
			app:layoutManager="LinearLayoutManager" />

		<com.ironwaterstudio.controls.ButtonEx
			android:id="@+id/btn_more"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_below="@id/rv_commentary"
			android:layout_centerHorizontal="true"
			android:textColor="@color/white"
			android:textSize="14sp"
			app:backgroundTint="@color/red_1" />

		<android.support.v4.widget.Space
			android:layout_width="match_parent"
			android:layout_height="10dp"
			android:layout_below="@id/btn_more"
			android:layout_centerHorizontal="true" />
	</RelativeLayout>
</android.support.v4.widget.NestedScrollView>