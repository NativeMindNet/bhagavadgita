<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="wrap_content">

	<RelativeLayout
		android:id="@+id/rl_chapter_info"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:background="?selectableItemBackground"
		android:clickable="true">

		<ImageView
			android:id="@+id/iv_arrow"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_alignParentRight="true"
			android:layout_centerVertical="true"
			android:paddingLeft="16.5dp"
			android:paddingRight="16.5dp"
			android:src="@drawable/arrow_show" />

		<com.ironwaterstudio.controls.TextViewEx
			android:id="@+id/tv_chapter"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_alignParentStart="true"
			android:layout_alignParentTop="true"
			android:layout_toLeftOf="@+id/iv_arrow"
			android:paddingLeft="16dp"
			android:paddingTop="11dp"
			android:textColor="@color/gray_2"
			android:textSize="14sp" />

		<com.ironwaterstudio.controls.TextViewEx
			android:id="@+id/tv_name_chapter"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_alignParentLeft="true"
			android:layout_below="@+id/tv_chapter"
			android:layout_toLeftOf="@+id/iv_arrow"
			android:paddingLeft="16dp"
			android:paddingTop="2dp"
			android:textColor="@color/gray_1"
			android:textSize="18sp" />

		<com.ironwaterstudio.controls.TextViewEx
			android:id="@+id/tv_slokas"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_alignParentLeft="true"
			android:layout_below="@+id/tv_name_chapter"
			android:layout_toLeftOf="@+id/iv_arrow"
			android:paddingBottom="10dp"
			android:paddingLeft="16dp"
			android:paddingTop="1dp"
			android:textColor="@color/gray_2"
			android:textSize="14sp"
			app:fontEx="italic" />
	</RelativeLayout>

	<android.support.v7.widget.RecyclerView
		android:id="@+id/rv_translations"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_below="@id/rl_chapter_info"
		android:background="@color/gray_5"
		app:layoutManager="GridLayoutManager" />
</RelativeLayout>