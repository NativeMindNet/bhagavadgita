<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent">

	<include
		android:id="@+id/toolbar"
		layout="@layout/item_toolbar" />

	<android.support.v4.widget.NestedScrollView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_below="@id/toolbar"
		android:scrollbars="vertical">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginLeft="@dimen/screen_offset"
			android:layout_marginRight="@dimen/screen_offset"
			android:background="@color/white"
			android:orientation="vertical">

			<LinearLayout
				android:id="@+id/btn_languages"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="?selectableItemBackground"
				android:clickable="true"
				android:orientation="vertical">

				<com.ironwaterstudio.controls.TextViewEx
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:paddingLeft="16dp"
					android:paddingTop="16dp"
					android:text="@string/language"
					android:textColor="@color/gray_1"
					android:textSize="16sp" />

				<com.ironwaterstudio.controls.TextViewEx
					android:id="@+id/tv_languages"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:paddingBottom="17dp"
					android:paddingLeft="16dp"
					android:paddingTop="3dp"
					android:textColor="@color/gray_2"
					android:textSize="14sp" />

			</LinearLayout>

			<View
				android:layout_width="match_parent"
				android:layout_height="1dp"
				android:background="@color/gray_4" />

			<com.ironwaterstudio.controls.TextViewEx
				android:layout_width="match_parent"
				android:layout_height="57dp"
				android:background="@color/white"
				android:paddingLeft="16dp"
				android:paddingTop="24dp"
				android:text="@string/show"
				android:textColor="@color/red_1"
				android:textSize="14sp" />

			<android.support.v7.widget.SwitchCompat
				android:id="@+id/sw_show_sanskrit"
				android:layout_width="match_parent"
				android:layout_height="52dp"
				android:background="@color/white"
				android:paddingLeft="16dp"
				android:paddingRight="16dp"
				android:text="@string/sanskrit"
				android:textColor="@color/gray_1" />

			<View
				android:layout_width="match_parent"
				android:layout_height="1dp"
				android:background="@color/gray_4" />

			<android.support.v7.widget.SwitchCompat
				android:id="@+id/sw_show_transcription"
				android:layout_width="match_parent"
				android:layout_height="52dp"
				android:background="@color/white"
				android:paddingLeft="16dp"
				android:paddingRight="16dp"
				android:text="@string/transcription"
				android:textColor="@color/gray_1" />

			<View
				android:layout_width="match_parent"
				android:layout_height="1dp"
				android:background="@color/gray_4" />

			<android.support.v7.widget.SwitchCompat
				android:id="@+id/sw_show_translation"
				android:layout_width="match_parent"
				android:layout_height="52dp"
				android:background="@color/white"
				android:paddingLeft="16dp"
				android:paddingRight="16dp"
				android:text="@string/word_by_word_translation"
				android:textColor="@color/gray_1"
				android:textSize="14sp" />

			<View
				android:layout_width="match_parent"
				android:layout_height="1dp"
				android:background="@color/gray_4" />

			<android.support.v7.widget.SwitchCompat
				android:id="@+id/sw_show_comments"
				android:layout_width="match_parent"
				android:layout_height="52dp"
				android:background="@color/white"
				android:paddingLeft="16dp"
				android:paddingRight="16dp"
				android:text="@string/comments"
				android:textColor="@color/gray_1"
				android:textSize="14sp" />

			<View
				android:layout_width="match_parent"
				android:layout_height="1dp"
				android:background="@color/gray_4" />

			<com.ironwaterstudio.controls.TextViewEx
				android:layout_width="match_parent"
				android:layout_height="57dp"
				android:background="@color/white"
				android:paddingLeft="16dp"
				android:paddingTop="24dp"
				android:text="@string/audio"
				android:textColor="@color/red_1"
				android:textSize="14sp" />

			<FrameLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content">

				<android.support.v7.widget.SwitchCompat
					android:id="@+id/sw_audio_translation"
					android:layout_width="match_parent"
					android:layout_height="52dp"
					android:background="@color/white"
					android:paddingLeft="16dp"
					android:paddingRight="16dp"
					android:text="@string/translation"
					android:textColor="@color/gray_1"
					android:textSize="14sp" />

				<com.ironwaterstudio.controls.ImageViewEx
					android:id="@+id/iv_translation_progress"
					android:layout_width="25dp"
					android:layout_height="25dp"
					android:layout_gravity="right|center_vertical"
					android:layout_marginRight="72dp"
					android:visibility="gone"
					app:scaleType="centerInside" />
			</FrameLayout>

			<View
				android:layout_width="match_parent"
				android:layout_height="1dp"
				android:background="@color/gray_4" />

			<FrameLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content">

				<android.support.v7.widget.SwitchCompat
					android:id="@+id/sw_audio_sanskrit"
					android:layout_width="match_parent"
					android:layout_height="52dp"
					android:background="@color/white"
					android:paddingLeft="16dp"
					android:paddingRight="16dp"
					android:text="@string/sanskrit"
					android:textColor="@color/gray_1"
					android:textSize="14sp" />

				<com.ironwaterstudio.controls.ImageViewEx
					android:id="@+id/iv_sanskrit_progress"
					android:layout_width="25dp"
					android:layout_height="25dp"
					android:layout_gravity="right|center_vertical"
					android:layout_marginRight="72dp"
					app:scaleTypeDefault="centerInside" />
			</FrameLayout>

			<View
				android:layout_width="match_parent"
				android:layout_height="1dp"
				android:background="@color/gray_4" />

			<android.support.v7.widget.SwitchCompat
				android:id="@+id/sw_audio_play_auto"
				android:layout_width="match_parent"
				android:layout_height="52dp"
				android:background="@color/white"
				android:paddingLeft="16dp"
				android:paddingRight="16dp"
				android:text="@string/play_auto"
				android:textColor="@color/gray_1"
				android:textSize="14sp" />

			<View
				android:layout_width="match_parent"
				android:layout_height="1dp"
				android:background="@color/gray_4" />

			<com.ironwaterstudio.controls.TextViewEx
				android:layout_width="match_parent"
				android:layout_height="57dp"
				android:background="@color/white"
				android:paddingLeft="16dp"
				android:paddingTop="24dp"
				android:text="@string/interpretations"
				android:textColor="@color/red_1"
				android:textSize="14sp" />

			<android.support.v7.widget.RecyclerView
				android:id="@+id/rv_books"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="@color/white"
				android:scrollbars="vertical"
				app:layoutManager="LinearLayoutManager" />
		</LinearLayout>
	</android.support.v4.widget.NestedScrollView>

	<View
		android:layout_width="match_parent"
		android:layout_height="5dp"
		android:layout_below="@id/toolbar"
		android:background="@drawable/shadow_bottom" />
</RelativeLayout>