<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
	package="com.ethnoapp.bgita">

	<uses-permission android:name="android.permission.INTERNET" />
	<uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
	<uses-permission android:name="android.permission.DOWNLOAD_WITHOUT_NOTIFICATION" />

	<application
		android:name=".ApplicationEx"
		android:allowBackup="true"
		android:icon="@drawable/launcher"
		android:label="@string/app_name"
		android:supportsRtl="true"
		android:theme="@style/AppTheme">
		<meta-data
			android:name="com.facebook.sdk.ApplicationId"
			android:value="@string/facebook_app_id" />

		<activity
			android:name=".screens.SplashActivity"
			android:screenOrientation="portrait"
			android:theme="@style/AppTheme.NavBar.WindowTransparent">
			<intent-filter>
				<action android:name="android.intent.action.MAIN" />
				<category android:name="android.intent.category.LAUNCHER" />
			</intent-filter>
		</activity>
		<activity
			android:name=".screens.GuideActivity"
			android:theme="@style/AppTheme.NavBar.WindowTransparent" />
		<activity
			android:name=".screens.MainActivity"
			android:label="@string/app_name"
			android:launchMode="singleTop"
			android:theme="@style/AppTheme">
			<intent-filter>
				<action android:name="android.intent.action.SEARCH" />
			</intent-filter>
			<meta-data
				android:name="android.app.searchable"
				android:resource="@xml/searchable" />
		</activity>
		<activity
			android:name=".screens.SettingsActivity"
			android:theme="@style/AppTheme" />
		<activity
			android:name=".screens.LanguagesActivity"
			android:theme="@style/AppTheme" />
		<activity
			android:name=".screens.QuoteActivity"
			android:theme="@style/AppTheme" />
		<!-- Used for Google Play Store Campaign Measurement-->
		<receiver
			android:name="com.google.android.gms.analytics.CampaignTrackingReceiver"
			android:enabled="true"
			android:exported="true">
			<intent-filter>
				<action android:name="com.android.vending.INSTALL_REFERRER" />
			</intent-filter>
		</receiver>

		<service android:name=".services.FirebaseMessagingServiceEx">
			<intent-filter>
				<action android:name="com.google.firebase.MESSAGING_EVENT" />
			</intent-filter>
		</service>
		<service android:name=".services.FirebaseInstanceIdServiceEx">
			<intent-filter>
				<action android:name="com.google.firebase.INSTANCE_ID_EVENT" />
			</intent-filter>
		</service>
	</application>
</manifest>