{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vocabulary.schema.json",
  "title": "Bhagavad Gita Vocabulary",
  "type": "object",
  "required": ["chapter", "vocabulary"],
  "properties": {
    "chapter": {
      "type": "integer",
      "minimum": 1,
      "maximum": 18
    },
    "meta": {
      "type": "object",
      "properties": {
        "totalWords": { "type": "integer" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "version": { "type": "string" },
        "source": { "type": "string", "const": "SM/SCSM/ШМ/ШЧСМ" }
      }
    },
    "vocabulary": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/vocabularyEntry"
      }
    }
  },
  "$defs": {
    "vocabularyEntry": {
      "type": "object",
      "required": ["id", "slokaId", "word", "transliteration", "meaning"],
      "properties": {
        "id": {
          "type": "integer",
          "description": "Unique vocabulary ID from CSV"
        },
        "slokaId": {
          "type": "integer",
          "description": "Reference to sloka ID"
        },
        "word": {
          "type": "string",
          "description": "Sanskrit word in Cyrillic transliteration (legacy format)"
        },
        "transliteration": {
          "type": "string",
          "description": "IAST/ISO transliteration for reference"
        },
        "meaning": {
          "type": "object",
          "required": ["ru"],
          "properties": {
            "ru": {
              "type": "object",
              "required": ["text", "approved"],
              "properties": {
                "text": { "type": "string" },
                "approved": { "type": "boolean", "default": true }
              }
            },
            "en": {
              "type": "object",
              "required": ["text", "approved"],
              "properties": {
                "text": { "type": "string" },
                "approved": { "type": "boolean", "default": true }
              }
            },
            "th": {
              "type": "object",
              "required": ["text", "approved"],
              "properties": {
                "text": { "type": "string" },
                "approved": { "type": "boolean", "default": false }
              }
            },
            "zh-CN": {
              "type": "object",
              "required": ["text", "approved"],
              "properties": {
                "text": { "type": "string" },
                "approved": { "type": "boolean", "default": false }
              }
            },
            "zh-TW": {
              "type": "object",
              "required": ["text", "approved"],
              "properties": {
                "text": { "type": "string" },
                "approved": { "type": "boolean", "default": false }
              }
            },
            "ko": {
              "type": "object",
              "required": ["text", "approved"],
              "properties": {
                "text": { "type": "string" },
                "approved": { "type": "boolean", "default": false }
              }
            },
            "ja": {
              "type": "object",
              "required": ["text", "approved"],
              "properties": {
                "text": { "type": "string" },
                "approved": { "type": "boolean", "default": false }
              }
            }
          }
        },
        "order": {
          "type": "integer",
          "description": "Word order within the sloka"
        }
      }
    }
  }
}
