{
  "vocabulary": {
    "22436": {
      "meaning": "Ee mzao wa Bharat",
      "transliteration": "He bhārata"
    },
    "22405": {
      "meaning": "Wa wawili hao",
      "transliteration": "tayoḥ"
    },
    "22412": {
      "meaning": "Na wenye maarifa",
      "transliteration": "vidvadbhiḥ"
    },
    "22328": {
      "meaning": "Huingia mwili mwingine",
      "transliteration": "śarīrāntaram saṁyāti"
    },
    "22355": {
      "meaning": "Wenye akili dhaifu",
      "transliteration": "achetasaḥ"
    },
    "22246": {
      "meaning": "Yananyoosha chini kama ndege za binadamu, wanyama, na spishi za chini",
      "transliteration": "adhaḥ prasṛtāḥ"
    },
    "22234": {
      "meaning": "Matawi yanaelekea chini, inawakilisha viumbe wote kutoka Brahmā hadi spishi za chini kabisa",
      "transliteration": "adhaḥ-śākham"
    },
    "22285": {
      "meaning": "Wamejitolea kwa kujitambua",
      "transliteration": "adhyātma-nityāḥ"
    },
    "22387": {
      "meaning": "Nimekaa kama mlinzi wa ndani, Roho Mkuu",
      "transliteration": "ahaṁ cha sanniviṣṭaḥ"
    },
    "22395": {
      "meaning": "Na mimi pekee ndiye lengo la kujulikana",
      "transliteration": "ahaṁ eva cha vedyaḥ"
    },
    "22397": {
      "meaning": "Katika umbo la Vedavyās, mimi ni Mfunuo wa Vedānta",
      "transliteration": "ahaṁ eva vedānta-kṛt"
    },
    "22404": {
      "meaning": "Na asiye kufa",
      "transliteration": "akṣaraḥ cha"
    },
    "22430": {
      "meaning": "Kwa roho zilizookolewa pia",
      "transliteration": "akṣarāt api"
    },
    "22250": {
      "meaning": "Kama sababu ya pili, kama utafutaji wa kufurahia matunda ya matendo, yameenea",
      "transliteration": "anusantatāni"
    },
    "22393": {
      "meaning": "Na kutoweka kwa vyote viwili",
      "transliteration": "apohanam cha"
    },
    "22264": {
      "meaning": "Shoka la kutokushikilia lililopatikana kutoka sādhu-saṅga, ushirika wa watakatifu",
      "transliteration": "asaṅga-śastreṇa"
    },
    "22255": {
      "meaning": "Ya mti wa Aśvattha unaowakilisha dunia hii",
      "transliteration": "asya"
    },
    "22235": {
      "meaning": "Na haina mwisho (kwa wale wanaotaka uhuru wa kufurahia matunda ya matendo yao)",
      "transliteration": "avyayam"
    },
    "22262": {
      "meaning": "Mti wa kupita wa dunia ya kimateriali",
      "transliteration": "aśvattham"
    },
    "22455": {
      "meaning": "Wenye akili nzuri ya kiungu",
      "transliteration": "buddhimān"
    },
    "22385": {
      "meaning": "Aina nne za vyakula",
      "transliteration": "chatuḥ-vidham annam"
    },
    "22237": {
      "meaning": "Ayati za ibada za Veda",
      "transliteration": "chandāṁsi"
    },
    "22288": {
      "meaning": "Kutoka kwa pacha",
      "transliteration": "dvandvaiḥ"
    },
    "22263": {
      "meaning": "Na kali",
      "transliteration": "dṛḍhena"
    },
    "22261": {
      "meaning": "Hii iliyozoelea (katika kuchukia Bwana Mkuu)",
      "transliteration": "enam suvirūḍha-mūlam"
    }
  }
}