{
  "vocabulary": {
    "22436": {
      "meaning": "Ey Bharat soyundan gelen",
      "transliteration": "He bhārata"
    },
    "22405": {
      "meaning": "İkisinden",
      "transliteration": "tayoḥ"
    },
    "22412": {
      "meaning": "Bilgili olanlar tarafından",
      "transliteration": "vidvadbhiḥ"
    },
    "22328": {
      "meaning": "Başka bir bedene girer",
      "transliteration": "śarīrāntaram saṁyāti"
    },
    "22355": {
      "meaning": "Zayıf anlayışlı olanlar",
      "transliteration": "achetasaḥ"
    },
    "22246": {
      "meaning": "İnsan, hayvan ve aşağı türlerin düzlemleri olarak aşağıya uzanır",
      "transliteration": "adhaḥ prasṛtāḥ"
    },
    "22234": {
      "meaning": "Dallar aşağıya bakar, Brahmā'dan en düşük türlere kadar tüm varlıkları temsil eder",
      "transliteration": "adhaḥ-śākham"
    },
    "22285": {
      "meaning": "Öz-realizasyona adanmış",
      "transliteration": "adhyātma-nityāḥ"
    },
    "22387": {
      "meaning": "İçsel gözetleyici, Yüce Ruh olarak bulunurum",
      "transliteration": "ahaṁ cha sanniviṣṭaḥ"
    },
    "22395": {
      "meaning": "Ve ben tek başıma bilinmesi gereken hedefim",
      "transliteration": "ahaṁ eva cha vedyaḥ"
    },
    "22397": {
      "meaning": "Vedavyās formunda, ben Vedānta'yı açıklayanım",
      "transliteration": "ahaṁ eva vedānta-kṛt"
    },
    "22404": {
      "meaning": "Ve ölümsüz olan",
      "transliteration": "akṣaraḥ cha"
    },
    "22430": {
      "meaning": "Kurtuluşa ermiş ruhlara da",
      "transliteration": "akṣarāt api"
    },
    "22250": {
      "meaning": "İkincil nedensel faktör olarak, eylemlerin meyvelerinden zevk alma arayışı olarak uzandı",
      "transliteration": "anusantatāni"
    },
    "22393": {
      "meaning": "Ve ikisinin de kayboluşu",
      "transliteration": "apohanam cha"
    },
    "22264": {
      "meaning": "Sādhu-saṅga'dan, azizlerin arkadaşlığından edinilen detachment baltası",
      "transliteration": "asaṅga-śastreṇa"
    },
    "22255": {
      "meaning": "Bu dünyayı temsil eden Aśvattha ağacının",
      "transliteration": "asya"
    },
    "22235": {
      "meaning": "Ve sonsuzdur (eylemlerinin meyvelerinden zevk alma bağımsızlığını arzulayanlar için)",
      "transliteration": "avyayam"
    },
    "22262": {
      "meaning": "Maddi dünyanın ölümlü ağacı",
      "transliteration": "aśvattham"
    },
    "22455": {
      "meaning": "İnce teistik mizaca sahip zeki kişiler",
      "transliteration": "buddhimān"
    },
    "22385": {
      "meaning": "Dört tür yiyecek",
      "transliteration": "chatuḥ-vidham annam"
    },
    "22237": {
      "meaning": "Vedaların ritüel ayetleri",
      "transliteration": "chandāṁsi"
    },
    "22288": {
      "meaning": "İkiliklerden",
      "transliteration": "dvandvaiḥ"
    },
    "22263": {
      "meaning": "Keskin olanla",
      "transliteration": "dṛḍhena"
    },
    "22261": {
      "meaning": "Bu inatla köklenmiş olanı (Yüce Rab'be karşı tiksinme içinde)",
      "transliteration": "enam suvirūḍha-mūlam"
    }
  }
}